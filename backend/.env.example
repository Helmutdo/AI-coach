# ── OpenRouter (AI Coach) ──────────────────────────────────────────────────────
# Get your key at https://openrouter.ai/keys
OPEN_ROUTER_APIKEY=
# Model to use (optional; default: openai/gpt-4o)
# Examples: anthropic/claude-3.5-sonnet, google/gemini-flash-1.5, openai/gpt-4o-mini
# OPENROUTER_MODEL=openai/gpt-4o

# ── Langfuse observability (optional) ─────────────────────────────────────────
# Create a project at https://cloud.langfuse.com (or self-host)
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=https://cloud.langfuse.com

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/postgres
# Fernet key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated or JSON array. No trailing slash.
# CORS_ORIGINS=http://localhost:3000,https://tu-app.vercel.app
# CORS_ORIGINS=["http://localhost:3000","https://tu-app.vercel.app"]

# ── Strava OAuth ──────────────────────────────────────────────────────────────
# https://www.strava.com/settings/api
# Set "Authorization Callback Domain" to match your redirect host.
# STRAVA_REDIRECT_URI must match exactly (scheme, host, port, path).
# Local dev:
#   STRAVA_REDIRECT_URI=http://127.0.0.1:8000/api/strava/callback
# Production:
#   STRAVA_REDIRECT_URI=https://your-api.up.railway.app/api/strava/callback
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=http://127.0.0.1:8000/api/strava/callback
STRAVA_FRONTEND_REDIRECT=http://localhost:3000/settings
