GARMIN_EMAIL=
GARMIN_PASSWORD=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Google AI Studio: https://aistudio.google.com/apikey — usar con AI_PROVIDER=google
GOOGLE_API_KEY=
# Modelo Gemini (opcional; por defecto gemini-2.0-flash en código)
# GEMINI_MODEL=gemini-2.0-flash
AI_PROVIDER=anthropic
DATABASE_URL=sqlite:///./garmin_coach.db
# Fernet key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=
# Orígenes CORS: lista separada por comas, o JSON array. Sin barra final.
# Producción: https://tu-app.vercel.app
# CORS_ORIGINS=http://localhost:3000,https://tu-app.vercel.app
# CORS_ORIGINS=["http://localhost:3000","https://tu-app.vercel.app"]

# Strava OAuth — https://www.strava.com/settings/api
# 1. Create an app; set "Authorization Callback Domain" to match your redirect host (e.g. localhost or your Railway host).
# 2. STRAVA_REDIRECT_URI must match exactly (scheme, host, port, path). API route is /api/strava/callback.
# Local dev example:
#   STRAVA_REDIRECT_URI=http://127.0.0.1:8000/api/strava/callback
# Production (replace host):
#   STRAVA_REDIRECT_URI=https://your-api.up.railway.app/api/strava/callback
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=http://127.0.0.1:8000/api/strava/callback
# Where Strava redirects the browser after OAuth (usually your Next app /settings)
STRAVA_FRONTEND_REDIRECT=http://localhost:3000/settings
