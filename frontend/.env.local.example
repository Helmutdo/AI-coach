# Backend API (FastAPI) — debe estar levantado (uvicorn) o el login no podrá crear usuario en backend
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# Auth.js — openssl rand -base64 32 (producción); en next dev hay fallback en auth.ts
AUTH_SECRET=
# Mismo origen que uses en el navegador (incl. puerto). Ej.: http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# Google Cloud → Credentials → OAuth 2.0 Client ID (tipo "Aplicación web")
# - Orígenes JS autorizados: http://localhost:3000
# - URIs de redirección: http://localhost:3000/api/auth/callback/google
# - Pantalla de consentimiento en "Prueba": añade tu correo en "Usuarios de prueba"
# Obligatorios (sin comillas vacías). Tras editar, reinicia el servidor de Next.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Opcional: mismo ID que arriba si solo tenías el nombre con prefijo público:
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=
