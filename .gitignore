# Monorepo root

# ── Secrets ───────────────────────────────────────────────────────────────────
.env
backend/.env
frontend/.env*.local

# ── Frontend ──────────────────────────────────────────────────────────────────
frontend/node_modules/
frontend/.next/

# ── Python (root-level catches; backend/.gitignore covers backend/) ───────────
__pycache__/
*.py[cod]
*.db
*.sqlite3
.pytest_cache/

# ── AI Assistant ──────────────────────────────────────────────────────────────
.claude/
.superpowers/
docs/superpowers/

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

